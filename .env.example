# Agent's own Azure setup
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=

# Agent's Entra App Registration (for provisioning)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Azure OAuth (for user-facing login — can reuse same Entra App or separate)
AZURE_OAUTH_CLIENT_ID=
AZURE_OAUTH_CLIENT_SECRET=

# Agent's public URL (used for OAuth redirect URI)
AGENT_BASE_URL=https://your-agent.azurecontainerapps.io

# Where the agent itself is hosted
PORT=3000
NODE_ENV=production
